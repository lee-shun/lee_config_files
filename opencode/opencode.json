{
  "$schema": "https://opencode.ai/config.json",
  "model":"llama.cpp/llamacpp_local",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llamacpp-server (local)",
      "options": {
        "baseURL": "http://192.168.1.105:8080/v1"
      },
      "models": {
        "llamacpp_local": {
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text"
            ]
          },
          "name": "llamacpp(local)",
          "limit": {
            "context": 4096000000,
            "output": 4096000000
          }
        }
      }
    }
  },
  "mcp": {
    "pulse-fetch": {
      "type": "local",
      "command": ["npx", "-y", "@pulsemcp/pulse-fetch"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser", "msedge"
      ],
      "enabled": true
    },
  }
}


